# Resend API Configuration (Required)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email Configuration (Required)
# Where form submissions are sent
CONTACT_EMAIL=admin@nexprove.com

# Sender email address
# Use onboarding@resend.dev for testing, or noreply@nexprove.com after domain verification
FROM_EMAIL=onboarding@resend.dev

# Optional: Google Sheets Integration
# Webhook URL for logging internship applications to Google Sheets
# Uncomment and add your webhook URL if needed:
# GOOGLE_SHEETS_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx

# Note: Google Analytics ID (G-4MTNEYDHY0) is hardcoded in src/app/[locale]/layout.tsx
# No environment variable needed for GA tracking

# ============================================
# HubSpot CRM Integration (Optional)
# ============================================
# Get your Private App API key from: https://app.hubspot.com/settings/integrations/private-apps
# Required for lead tracking and CRM integration
# HUBSPOT_API_KEY=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ============================================
# CallRail Call Tracking (Optional)
# ============================================
# Get your API key from: https://app.callrail.com/settings/api
# Required for call tracking and dynamic number insertion
# CALLRAIL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Base URL Configuration
# ============================================
# Used for generating absolute URLs in emails and lead magnets
# Production: https://nexprove.com
# Development: http://localhost:3000
NEXT_PUBLIC_BASE_URL=https://nexprove.com

# ============================================
# Twilio Configuration (Optional - for US phone number)
# ============================================
# Get credentials from: https://console.twilio.com
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ============================================
# Public Phone Numbers (Frontend Display)
# ============================================
# These are visible in the browser and used for click-to-call links
# US Office Phone (Twilio Number - when configured)
NEXT_PUBLIC_PHONE_US=+1XXXXXXXXXX
NEXT_PUBLIC_PHONE_US_DISPLAY=+1 (XXX) XXX-XXXX
NEXT_PUBLIC_PHONE_US_LOCAL=(XXX) XXX-XXXX

# Other Office Phones (Update when virtual offices are set up)
# NEXT_PUBLIC_PHONE_CA=+1XXXXXXXXXX
# NEXT_PUBLIC_PHONE_DE=+49XXXXXXXXXX
# NEXT_PUBLIC_PHONE_NG=+234XXXXXXXXXX
