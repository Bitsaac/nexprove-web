# Resend API Configuration (Required)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email Configuration (Required)
# Where form submissions are sent
CONTACT_EMAIL=admin@nexprove.com

# Sender email address
# Use onboarding@resend.dev for testing, or noreply@nexprove.com after domain verification
FROM_EMAIL=onboarding@resend.dev

# Optional: Google Sheets Integration
# Webhook URL for logging internship applications to Google Sheets
# Uncomment and add your webhook URL if needed:
# GOOGLE_SHEETS_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx

# Note: Google Analytics ID (G-4MTNEYDHY0) is hardcoded in src/app/[locale]/layout.tsx
# No environment variable needed for GA tracking
